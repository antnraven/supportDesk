<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">


    <changeSet id="1" author="MilovAV">
        <createTable tableName="users">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="role" type="varchar(150)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(150)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="userFullname" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="userLogin" type="varchar(150)">
                <constraints nullable="false"/>
            </column>
            <column name="phoneNumber" type="VARCHAR(15)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="email" type="varchar(150)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="workplace" type="varchar(150)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>